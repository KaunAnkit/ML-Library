   "outputs": [],
   "source": [
    "def accuracy(y_pred,y_true):\n",
    "\n",
    "    y_true , y_pred = np.array(y_true), np.array(y_pred)\n",
    "\n",
    "    y_pred = (y_pred >= 0.5).astype(int)\n",
    "\n",
    "\n",
    "    return np.mean(y_pred == y_true)"
   ]
