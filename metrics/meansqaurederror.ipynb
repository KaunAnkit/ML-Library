   "source": [
    "def mean_squared_error(y_pred,y_true):\n",
    "\n",
    "    y_true , y_pred = np.array(y_true), np.array(y_pred)\n",
    "\n",
    "    return np.mean((y_true - y_pred)**2)\n",
    "    "
   ]
